# Nexus CRM — variáveis do app (Expo).
# Copie para .env e preencha. Tudo com prefixo EXPO_PUBLIC_ é embutido no bundle
# em build — reinicie o Metro com `npx expo start -c` após mudar qualquer valor.

# ─── Supabase (dados + login) ───
# Project Settings → API no dashboard do Supabase.
EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_ou_anon_key

# ─── Proxy de IA (apps/api) ───
# Simulador iOS: http://localhost:3000
# Emulador Android: http://10.0.2.2:3000
# Celular físico: http://<IP-LAN-do-PC>:3000  (ipconfig getifaddr en0)  ou a URL do ngrok
# Sem esta variável, o app roda a IA em Modo Sandbox (respostas simuladas).
EXPO_PUBLIC_API_URL=http://localhost:3000
