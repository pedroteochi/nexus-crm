# ─── OpenAI (a chave vive AQUI, nunca no dispositivo) ───
OPENAI_API_KEY=sk-proj-xxxxxxxx

# ─── Servidor ───
PORT=3000

# ─── Supabase (obrigatório) ───
# O proxy valida o access_token da sessão do usuário via auth.getUser.
# A anon/publishable key basta — a service_role NÃO é necessária.
# Project Settings → API no dashboard do Supabase.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx_ou_anon_key

# ─── Bootstrap local SEM Supabase (opcional) ───
# Aceito SOMENTE quando SUPABASE_URL/ANON_KEY estão ausentes — com o Supabase
# configurado, o servidor ignora este segredo (não é um bypass de auth).
# DEV_SHARED_SECRET=troque-isto-por-algo-aleatorio
